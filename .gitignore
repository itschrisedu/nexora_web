# -----------------------------------------------------------------------------
# NEXORA Web — .gitignore Profesional para Next.js & Node.js
# -----------------------------------------------------------------------------

# Dependencias
node_modules/
/jspm_packages/
.pnpm-store/

# Next.js - Carpetas de compilación y caché
.next/
out/
build/
dist/

# Archivos de depuración y logs de NPM
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
.pnpm-debug.log*

# Variables de entorno y secretos (¡NUNCA subir a control de versiones!)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env*.local

# Cobertura de pruebas (Testing)
coverage/
.nyc_output/

# Caché de herramientas de desarrollo (Linters, Formatters)
.eslintcache
.stylelintcache
.prettiercache
.parcel-cache
.cache/
.next-env.d.ts

# Configuraciones de IDEs y Editores de código
.vscode/*
!.vscode/extensions.json
!.vscode/launch.json
!.vscode/settings.json
!.vscode/tasks.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Archivos temporales del Sistema Operativo
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db
Desktop.ini

# Archivos temporales de TypeScript
*.tsbuildinfo

# Archivos generados locales
.vercel
.netlify
